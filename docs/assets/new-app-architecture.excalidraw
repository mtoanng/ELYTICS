      ],
      "updated": 1782209098354,
      "link": null,
      "locked": false,
      "text": "Backend API (FastAPI or similar)\n- OIDC auth / RBAC\n- stable page-independent API contracts\n- chooses correct grain/source per request\n- metadata endpoints from OLTP layer\n- timeseries endpoints from serving layer\n- caching only for hot/small exact responses\n- compression, observability, rate limiting\n\n",
      "fontSize": 18,
      "fontFamily": 1,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": null,
      "originalText": "Backend API (FastAPI or similar)\n- OIDC auth / RBAC\n- stable page-independent API contracts\n- chooses correct grain/source per request\n- metadata endpoints from OLTP layer\n- timeseries endpoints from serving layer\n- caching only for hot/small exact responses\n- compression, observability, rate limiting\n\n",
      "lineHeight": 1.25,
      "index": "aA",
      "autoResize": true
    },
