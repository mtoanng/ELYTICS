      "boundElements": [],
      "updated": 1782207893651,
      "link": null,
      "locked": false,
      "text": "Frontend\nReact + TypeScript + TanStack Query + Plotly or ECharts\nPragmatic alternative: Dash only if scope stays dashboard-like\n\nClient responsibilities:\n- keep zoom/pan local\n- fetch only on explicit filter/range changes\n- virtualized tables and incremental UI loading\n- optional Web Workers for local transforms / ONNX\n- current page data stored client-side, not whole corpus",
      "fontSize": 18,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": null,
      "originalText": "Frontend\nReact + TypeScript + TanStack Query + Plotly or ECharts\nPragmatic alternative: Dash only if scope stays dashboard-like\n\nClient responsibilities:\n- keep zoom/pan local\n- fetch only on explicit filter/range changes\n- virtualized tables and incremental UI loading\n- optional Web Workers for local transforms / ONNX\n- current page data stored client-side, not whole corpus",
      "lineHeight": 1.25,
      "index": "aE",
      "autoResize": true
    },
