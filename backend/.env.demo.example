# Backend local demo example
# Copy to backend/.env and fill values as needed.

ENVIRONMENT=development
PYTHONPATH=/app

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Outbound corporate proxy for Databricks SQL calls
HTTP_PROXY=http://139.15.111.168:8080
HTTPS_PROXY=http://139.15.111.168:8080
http_proxy=http://139.15.111.168:8080
https_proxy=http://139.15.111.168:8080
NO_PROXY=backend,frontend,redis,localhost,127.0.0.1,host.docker.internal,.bosch.com
no_proxy=backend,frontend,redis,localhost,127.0.0.1,host.docker.internal,.bosch.com

# Databricks SQL Warehouse
DATABRICKS_SERVER_HOSTNAME=
DATABRICKS_HTTP_PATH=

# Recommended for deploy/demo: Azure service principal machine-to-machine auth.
# Store the secret in Key Vault or the container platform secret store; do not commit it.
DATABRICKS_AUTH_TYPE=azure-sp-m2m
DATABRICKS_AZURE_CLIENT_ID=
DATABRICKS_AZURE_CLIENT_SECRET=
DATABRICKS_AZURE_TENANT_ID=
# Optional but recommended for Azure Databricks when available:
DATABRICKS_AZURE_WORKSPACE_RESOURCE_ID=

# Local fallback only: Databricks PAT/access token. Leave empty when using azure-sp-m2m.
DATABRICKS_TOKEN=

# Databricks SQL connector pool tuning. Keep small for demo cost control.
DATABRICKS_POOL_SIZE=4
DATABRICKS_MAX_OVERFLOW=1
DATABRICKS_POOL_RECYCLE_SECONDS=3600

# CO reporting serving tables
CO_GOLD_CATALOG=ps_xplatform_dev
CO_GOLD_SCHEMA=co2elyd_dev
CO_GOLD_RAW_TABLE=gold_timeseries
CO_GOLD_AGG_1M_TABLE=gold_timeseries_agg_1min
CO_GOLD_AGG_15M_TABLE=gold_timeseries_agg_15min
CO_GOLD_AGG_60M_TABLE=gold_timeseries_agg_60min
CO_GOLD_EXPERIMENT_INDEX_TABLE=gold_experiment_index
CO_GOLD_CHANNEL_CATALOG_EXPERIMENT_TABLE=gold_channel_catalog_experiment

# Final Elytics serving model: raw + 1min + 15min + 60min.
CO_REPORTING_ENABLED_RESOLUTIONS=raw,agg_1m,agg_15m,agg_60m

# Cache/query tuning
CO_REPORTING_TTL_SECONDS=43200
CO_REPORTING_DEFAULT_PREFETCH_SECONDS=1800
CO_REPORTING_RAW_MAX_SPAN_SECONDS=7200
CO_REPORTING_AGG_1M_MAX_SPAN_SECONDS=86400
CO_REPORTING_AGG_15M_MAX_SPAN_SECONDS=604800
