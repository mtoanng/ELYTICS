# Backend local demo example
# Copy to backend/.env and fill values as needed.

ENVIRONMENT=development
PYTHONPATH=/app

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Databricks SQL Warehouse
DATABRICKS_SERVER_HOSTNAME=
DATABRICKS_HTTP_PATH=
DATABRICKS_TOKEN=

# Azure auth (real mode)
BACKEND_AZURE_TENANT_ID=
BACKEND_AZURE_CLIENT_ID=

# Local demo shortcut
# Set to true only for local demo if you want to bypass token verification.
DISABLE_AUTH=true

# CO reporting serving tables
CO_GOLD_CATALOG=ps_xplatform_dev
CO_GOLD_SCHEMA=co2elyd_dev
CO_GOLD_RAW_TABLE=gold_timeseries
CO_GOLD_AGG_TABLE=gold_timeseries_agg
CO_GOLD_AGG_15M_TABLE=gold_timeseries_agg_15min
CO_GOLD_AGG_60M_TABLE=gold_timeseries_agg_60min
CO_GOLD_EXPERIMENT_INDEX_TABLE=gold_experiment_index
CO_GOLD_CHANNEL_CATALOG_TABLE=gold_channel_catalog
CO_GOLD_SUMMARY_TABLE=gold_summary_statistics

# Keep this conservative for the current demo path. Add agg_15m/agg_60m only
# after those serving tables are present in the dev catalog.
CO_REPORTING_ENABLED_RESOLUTIONS=raw,agg_1m

# Cache/query tuning
CO_REPORTING_TTL_SECONDS=43200
CO_REPORTING_DEFAULT_PREFETCH_SECONDS=1800
CO_REPORTING_RAW_MAX_SPAN_SECONDS=7200
CO_REPORTING_AGG_1M_MAX_SPAN_SECONDS=86400
CO_REPORTING_AGG_15M_MAX_SPAN_SECONDS=604800
