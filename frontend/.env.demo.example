# Frontend local demo example
# Copy to frontend/.env and fill values as needed.

PYTHONPATH=/app
BACKEND_API_URL=http://backend:8000

# Keep frontend-to-backend and Redis calls inside the Docker network.
NO_PROXY=backend,frontend,redis,localhost,127.0.0.1,host.docker.internal,.bosch.com
no_proxy=backend,frontend,redis,localhost,127.0.0.1,host.docker.internal,.bosch.com

# Redis-backed Flask session store
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
SESSION_LIFETIME_SECONDS=604800

# Optional debug run mode
USE_DASH_DEBUG_SERVER=false
