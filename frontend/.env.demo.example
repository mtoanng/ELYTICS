# Frontend local demo example
# Copy to frontend/.env and fill values as needed.

PYTHONPATH=/app
BACKEND_API_URL=http://backend:8000

# Local demo shortcut. Keep in sync with backend DISABLE_AUTH.
DISABLE_AUTH=true

# Redis-backed Flask session store
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
SESSION_LIFETIME_SECONDS=604800

# Real Azure/OIDC mode
FRONTEND_OIDC_SECRET_KEY=
FRONTEND_AZURE_CLIENT_ID=
FRONTEND_AZURE_CLIENT_SECRET=
FRONTEND_AZURE_TENANT_ID=
BACKEND_AZURE_CLIENT_ID=

# Optional debug run mode
USE_DASH_DEBUG_SERVER=false
